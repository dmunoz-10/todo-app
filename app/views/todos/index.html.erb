<% content_for :title, "Todos" %>

<%= turbo_stream_from "todos" %>

<div class="w-full flex flex-col gap-6">
  <h1 class="font-bold text-4xl mobile-app:hidden">Todos</h1>

  <%= turbo_frame_tag "todos", class: "flex flex-col gap-2" do %>
    <%= render @todos %>
  <% end %>

  <%= turbo_frame_tag dom_id(@todo), class: "mobile-app:order-first" do %>
    <%= render partial: "todos/new_button" %>
  <% end %>
</div>
